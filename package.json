{
  "name": "hoha-ui",
  "version": "0.0.1",
  "private": true,
  "description": "A Vue 2/3 component library with utils",
  "scripts": {
    "dev": "pnpm -F playground dev",
    "build": "pnpm -r build",
    "build:components": "pnpm -F @hohaya/hoho build",
    "build:utils": "pnpm -F @hohaya/hoho-utils build",
    "docs:dev": "pnpm -F docs dev",
    "docs:build": "pnpm -F docs build",
    "lint": "eslint packages --ext .js,.ts,.vue",
    "lint:fix": "eslint packages --ext .js,.ts,.vue --fix",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "release:manual": "node scripts/release.js"
  },
  "keywords": [
    "vue",
    "components",
    "utils",
    "vue2",
    "vue3"
  ],
  "author": "hoha",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@changesets/cli": "^2.30.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.22.0",
    "postcss": "^8.5.9",
    "postcss-pxtorem": "^6.1.0",
    "prettier": "^3.2.0",
    "rollup-plugin-less": "^1.1.3",
    "rollup-plugin-postcss": "^4.0.2",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0"
  }
}
