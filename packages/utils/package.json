{
  "name": "@hoha/utils",
  "version": "0.0.1",
  "description": "Utility functions library",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "utils",
    "javascript",
    "typescript"
  ],
  "author": "hoha",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^20.11.0",
    "rollup": "^4.9.0",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0"
  },
  "scripts": {
    "prebuild": "tsc --declaration --declarationMap --outDir temp src/index.ts && echo 'TypeScript compiled'",
    "build": "rollup -c rollup.config.mjs && cp temp/index.d.ts dist/",
    "postbuild": "rm -rf temp",
    "test": "vitest"
  }
}
