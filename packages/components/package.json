{
  "name": "@hohaya/hoho",
  "version": "0.0.1",
  "description": "Vue 2/3 component library",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "types": "dist/index.d.ts",
  "style": "dist/style.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "browser": "./dist/index.umd.js"
    },
    "./compat": {
      "types": "./src/compat/index.ts",
      "import": "./src/compat/index.ts",
      "require": "./src/compat/index.ts"
    },
    "./src/compat": {
      "types": "./src/compat/index.ts",
      "import": "./src/compat/index.ts",
      "require": "./src/compat/index.ts"
    },
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "vue",
    "components",
    "ui",
    "vue2",
    "vue3"
  ],
  "author": "hoha",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vue": "^2.6.0 || ^3.0.0"
  },
  "dependencies": {
    "@hoha/utils": "workspace:*",
    "@vue/composition-api": "^1.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "less": "^4.2.0",
    "rollup": "^4.9.0",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-less": "^1.1.3",
    "rollup-plugin-vue": "^6.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.3.0",
    "vue": "^3.4.0"
  },
  "scripts": {
    "dev": "vite build --watch",
    "prebuild": "tsc --declaration --declarationMap --emitDeclarationOnly --outDir temp src/index.ts 2>/dev/null || true && echo 'TypeScript declarations generated'",
    "build": "rollup -c rollup.config.mjs",
    "postbuild": "if [ -f temp/index.d.ts ]; then cp temp/index.d.ts dist/; fi && rm -rf temp",
    "test": "vitest"
  }
}
